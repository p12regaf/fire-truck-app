# Entorno virtual de Python
.venv/

# Archivos de configuración locales específicos del dispositivo
# ¡IMPORTANTE! Esto evita que la configuración local sea sobrescrita.
config/config.yaml

# Archivos de caché de Python
__pycache__/
*.pyc

# Archivos de estado de sesión (generados en runtime)
session_health.json
shutdown_state.json